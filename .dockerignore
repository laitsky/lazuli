# =============================================================================
# Docker Ignore File
# =============================================================================
# Excludes unnecessary files from the Docker build context to speed up builds
# and reduce image size.
# =============================================================================

# Dependencies - will be reinstalled in container
node_modules
**/node_modules

# Build outputs - will be rebuilt in container
dist
**/dist
.next
**/.next
out
**/out

# Turbo cache
.turbo
**/.turbo

# Environment files (should be passed at runtime)
.env
.env.*
!.env.example

# IDE and editor files
.idea
.vscode
*.swp
*.swo
*~

# Git
.git
.gitignore

# Documentation (not needed in production)
*.md
!README.md
docs

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__
**/__tests__
coverage
**/coverage

# Development tools
.husky
.eslintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Docker files (prevent recursive copy)
Dockerfile
**/Dockerfile
docker-compose*.yml
