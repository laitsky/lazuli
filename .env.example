# Lazuli local development defaults
#
# Production configuration is managed through Cloudflare Wrangler vars,
# bindings, and secrets. Do not put production secrets in this file.

ENVIRONMENT=local
PUBLIC_API_BASE_URL=http://localhost:8787
CORS_ORIGIN=http://localhost:3001

# Required only for local testing of admin endpoints. Staging and production use
# ADMIN_API_KEY_ID plus ADMIN_SIGNING_SECRET and reject this header-only mode.
ADMIN_API_KEY=replace-with-local-admin-key

# Staging/production setup:
#   bunx wrangler secret put ADMIN_SIGNING_SECRET --env staging
#   bunx wrangler secret put ADMIN_SIGNING_SECRET --env production
