PORT=3000
NODE_ENV=development
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Redis Configuration (optional - falls back to in-memory cache if not enabled)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS Configuration
# Comma-separated list of allowed origins (defaults to https://lazuli.now)
CORS_ORIGIN=http://localhost:3001