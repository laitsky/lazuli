{
  "name": "lazuli",
  "version": "1.0.0",
  "description": "Full-stack cryptocurrency trading tool with real-time data",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@lazuli/api",
    "dev:api": "npm run dev --workspace=@lazuli/api",
    "dev:web": "npm run dev --workspace=@lazuli/web",
    "dev:all": "npm run dev:api & npm run dev:web",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=@lazuli/api",
    "build:web": "npm run build --workspace=@lazuli/web",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/.next apps/*/dist"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "api",
    "nextjs",
    "monorepo",
    "binance",
    "bybit",
    "okx",
    "hyperliquid"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
