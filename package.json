{
  "name": "lazuli",
  "version": "0.1.0-alpha",
  "description": "Full-stack cryptocurrency trading tool with real-time data",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/config/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@lazuli/api",
    "dev:web": "turbo run dev --filter=@lazuli/web",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@lazuli/api",
    "build:web": "turbo run build --filter=@lazuli/web",
    "build:cloudflare": "bun run build:api && bun run build:web && cd apps/web && bun run build:worker",
    "start:api": "cd apps/api && bun run dist/index.js",
    "start:web": "cd apps/web && bunx --bun vite preview --host",
    "dev:cloudflare": "wrangler dev -c apps/api/wrangler.jsonc -c apps/web/wrangler.jsonc",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "api",
    "react",
    "vite",
    "monorepo",
    "turborepo",
    "binance",
    "bybit",
    "okx"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.1.38",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "form-data": "^4.0.4",
    "brace-expansion": "^1.1.15",
    "fast-uri": "^3.1.2",
    "flatted": "^3.4.2",
    "js-yaml": "^4.2.0",
    "picomatch": "^4.0.4",
    "rollup": "^4.62.2",
    "yaml": "^2.9.0",
    "@sentry/browser": "^7.119.1"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "apps/api/**/*.{ts,tsx,js,jsx}": [
      "bunx eslint --fix --config apps/api/eslint.config.js",
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx,js,jsx}": [
      "bunx eslint --fix",
      "prettier --write"
    ],
    "*.{ts,js,jsx}": [
      "bunx eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
