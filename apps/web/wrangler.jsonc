{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lazuli-web",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-19",
  "workers_dev": true,

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true,
  },

  "services": [
    {
      "binding": "API_SERVICE",
      "service": "lazuli-api",
    },
  ],

  "observability": {
    "enabled": true,
  },

  "env": {
    "staging": {
      "name": "lazuli-web-staging",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "staging.lazuli.now/*",
          "zone_name": "lazuli.now",
        },
      ],
      "services": [
        {
          "binding": "API_SERVICE",
          "service": "lazuli-api-staging",
        },
      ],
    },
    "production": {
      "name": "lazuli-web",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "lazuli.now/*",
          "zone_name": "lazuli.now",
        },
        {
          "pattern": "www.lazuli.now/*",
          "zone_name": "lazuli.now",
        },
      ],
      "services": [
        {
          "binding": "API_SERVICE",
          "service": "lazuli-api",
        },
      ],
    },
  },
}
