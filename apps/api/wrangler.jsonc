{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lazuli-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "limits": {
    "cpu_ms": 5000,
  },

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": false,
    },
  },

  "triggers": {
    "crons": ["*/5 * * * *"],
  },

  "vars": {
    "ENVIRONMENT": "local",
    "REALTIME_INGEST_ENABLED": "true",
    "APP_BASE_URL": "http://localhost:8788",
    "PUBLIC_API_BASE_URL": "http://localhost:8787",
    "CORS_ORIGIN": "http://localhost:3001,http://localhost:8788",
    "INGEST_SIGNING_SECRET_ID": "ingest-local-v1",
    "METRICS_INGEST_SECRET_ID": "metrics-local-v1",
    "REALTIME_TOKEN_SECRET_ID": "realtime-local-v1",
    "NOTIFICATION_ENCRYPTION_KEY_ID": "notifications-local-v1",
    "ALERT_WEBHOOK_SIGNING_SECRET_ID": "alert-webhook-local-v1",
    "MAGIC_LINK_EMAIL_FROM": "signin@lazuli.now",
    "ALERT_EMAIL_FROM": "alerts@lazuli.now",
    "OPERATIONAL_OWNER": "lazuli-operations",
    "OPS_READ_SECRET": "local-ops",
    "INGEST_HEALTH_URL": "http://localhost:8790/control/health",
    "ALERT_USER_WEBHOOKS_ENABLED": "true",
    "ACCOUNT_FEATURES_ENABLED": "true",
    "ALERT_EVALUATION_ENABLED": "true",
    "ADMIN_ROUTES_ENABLED": "true",
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lazuli-db",
      "database_id": "local",
      "migrations_dir": "migrations",
    },
  ],

  "r2_buckets": [
    {
      "binding": "OHLCV_ARCHIVE",
      "bucket_name": "lazuli-ohlcv-local",
    },
  ],

  "queues": {
    "producers": [
      {
        "binding": "BACKFILL_QUEUE",
        "queue": "lazuli-backfill-local",
      },
      {
        "binding": "ALERT_DELIVERY_QUEUE",
        "queue": "lazuli-alert-delivery-local",
      },
    ],
    "consumers": [
      {
        "queue": "lazuli-backfill-local",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "lazuli-backfill-dlq-local",
      },
      {
        "queue": "lazuli-alert-delivery-local",
        "max_batch_size": 10,
        "max_batch_timeout": 2,
        "max_retries": 5,
        "dead_letter_queue": "lazuli-alert-delivery-dlq-local",
      },
    ],
  },

  "workflows": [
    {
      "name": "lazuli-backfill-local",
      "binding": "BACKFILL_WORKFLOW",
      "class_name": "BackfillWorkflow",
      "limits": {
        "steps": 25000,
      },
    },
  ],

  "analytics_engine_datasets": [
    {
      "binding": "API_ANALYTICS",
      "dataset": "lazuli_api_local",
    },
  ],

  "ratelimits": [
    {
      "name": "PUBLIC_RATE_LIMITER",
      "namespace_id": "698140701",
      "simple": { "limit": 240, "period": 60 },
    },
    {
      "name": "EXPENSIVE_RATE_LIMITER",
      "namespace_id": "698140702",
      "simple": { "limit": 30, "period": 60 },
    },
    {
      "name": "BUILDER_PUBLIC_RATE_LIMITER",
      "namespace_id": "698140703",
      "simple": { "limit": 1200, "period": 60 },
    },
    {
      "name": "BUILDER_EXPENSIVE_RATE_LIMITER",
      "namespace_id": "698140704",
      "simple": { "limit": 120, "period": 60 },
    },
    {
      "name": "EXCHANGE_RATE_LIMITER",
      "namespace_id": "698140705",
      "simple": { "limit": 50, "period": 10 },
    },
    {
      "name": "ADMIN_RATE_LIMITER",
      "namespace_id": "698140706",
      "simple": { "limit": 15, "period": 60 },
    },
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "MARKET_DATA_CACHE",
        "class_name": "MarketDataCacheV2DO",
      },
      {
        "name": "REALTIME_HUB",
        "class_name": "RealtimeHubV2DO",
      },
      {
        "name": "REALTIME_SEQUENCER",
        "class_name": "RealtimeSequencerV1DO",
      },
      {
        "name": "REALTIME_FANOUT",
        "class_name": "RealtimeFanoutV3DO",
      },
    ],
  },

  "migrations": [
    {
      "tag": "resource-safe-v1",
      "new_sqlite_classes": ["MarketDataCacheV2DO", "RealtimeHubV2DO"],
    },
    {
      "tag": "realtime-batched-fanout-v2",
      "new_sqlite_classes": ["RealtimeSequencerV1DO", "RealtimeFanoutV3DO"],
    },
  ],

  "env": {
    "staging": {
      "name": "lazuli-api-staging",
      "workers_dev": true,
      "limits": {
        "cpu_ms": 5000,
      },
      "observability": {
        "enabled": true,
        "head_sampling_rate": 0.1,
        "logs": {
          "enabled": true,
          "head_sampling_rate": 0.1,
          "invocation_logs": false,
        },
      },
      "triggers": {
        "crons": ["*/5 * * * *"],
      },
      "vars": {
        "ENVIRONMENT": "staging",
        "REALTIME_INGEST_ENABLED": "false",
        "APP_BASE_URL": "https://staging.lazuli.now",
        "PUBLIC_API_BASE_URL": "https://api-staging.lazuli.now",
        "CORS_ORIGIN": "https://staging.lazuli.now",
        "ADMIN_API_KEY_ID": "lazuli-admin-staging",
        "INGEST_SIGNING_SECRET_ID": "ingest-staging-v1",
        "METRICS_INGEST_SECRET_ID": "metrics-staging-v1",
        "REALTIME_TOKEN_SECRET_ID": "realtime-staging-v1",
        "NOTIFICATION_ENCRYPTION_KEY_ID": "notifications-staging-v1",
        "ALERT_WEBHOOK_SIGNING_SECRET_ID": "alert-webhook-staging-v1",
        "MAGIC_LINK_EMAIL_FROM": "signin@lazuli.now",
        "ALERT_EMAIL_FROM": "alerts@lazuli.now",
        "OPERATIONAL_OWNER": "lazuli-operations",
        "INGEST_HEALTH_URL": "https://ingest-staging.lazuli.now/control/health",
        "ALERT_USER_WEBHOOKS_ENABLED": "true",
        "ACCOUNT_FEATURES_ENABLED": "false",
        "ALERT_EVALUATION_ENABLED": "false",
        "ADMIN_ROUTES_ENABLED": "false",
      },
      "send_email": [
        {
          "name": "MAGIC_LINK_EMAIL",
          "allowed_sender_addresses": ["signin@lazuli.now"],
        },
        {
          "name": "ALERT_EMAIL",
          "allowed_sender_addresses": ["alerts@lazuli.now"],
        },
      ],
      "routes": [
        {
          "pattern": "api-staging.lazuli.now",
          "custom_domain": true,
        },
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "lazuli-db-staging",
          "database_id": "09fb35f7-b0af-40b1-93e0-de1691bcdbf9",
          "migrations_dir": "migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "OHLCV_ARCHIVE",
          "bucket_name": "lazuli-ohlcv-staging",
        },
      ],
      "queues": {
        "producers": [
          {
            "binding": "BACKFILL_QUEUE",
            "queue": "lazuli-backfill-staging",
          },
          {
            "binding": "ALERT_DELIVERY_QUEUE",
            "queue": "lazuli-alert-delivery-staging",
          },
        ],
        "consumers": [
          {
            "queue": "lazuli-backfill-staging",
            "max_batch_size": 10,
            "max_batch_timeout": 5,
            "max_retries": 5,
            "dead_letter_queue": "lazuli-backfill-dlq-staging",
          },
          {
            "queue": "lazuli-alert-delivery-staging",
            "max_batch_size": 10,
            "max_batch_timeout": 2,
            "max_retries": 5,
            "dead_letter_queue": "lazuli-alert-delivery-dlq-staging",
          },
        ],
      },
      "workflows": [
        {
          "name": "lazuli-backfill-staging",
          "binding": "BACKFILL_WORKFLOW",
          "class_name": "BackfillWorkflow",
          "limits": {
            "steps": 25000,
          },
        },
      ],
      "analytics_engine_datasets": [
        {
          "binding": "API_ANALYTICS",
          "dataset": "lazuli_api_staging",
        },
      ],
      "ratelimits": [
        {
          "name": "PUBLIC_RATE_LIMITER",
          "namespace_id": "698140711",
          "simple": { "limit": 240, "period": 60 },
        },
        {
          "name": "EXPENSIVE_RATE_LIMITER",
          "namespace_id": "698140712",
          "simple": { "limit": 30, "period": 60 },
        },
        {
          "name": "BUILDER_PUBLIC_RATE_LIMITER",
          "namespace_id": "698140713",
          "simple": { "limit": 1200, "period": 60 },
        },
        {
          "name": "BUILDER_EXPENSIVE_RATE_LIMITER",
          "namespace_id": "698140714",
          "simple": { "limit": 120, "period": 60 },
        },
        {
          "name": "EXCHANGE_RATE_LIMITER",
          "namespace_id": "698140715",
          "simple": { "limit": 50, "period": 10 },
        },
        {
          "name": "ADMIN_RATE_LIMITER",
          "namespace_id": "698140716",
          "simple": { "limit": 15, "period": 60 },
        },
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "MARKET_DATA_CACHE",
            "class_name": "MarketDataCacheV2DO",
          },
          {
            "name": "REALTIME_HUB",
            "class_name": "RealtimeHubV2DO",
          },
          {
            "name": "REALTIME_SEQUENCER",
            "class_name": "RealtimeSequencerV1DO",
          },
          {
            "name": "REALTIME_FANOUT",
            "class_name": "RealtimeFanoutV3DO",
          },
        ],
      },
    },
    "production": {
      "name": "lazuli-api",
      "workers_dev": false,
      "limits": {
        "cpu_ms": 5000,
      },
      "observability": {
        "enabled": true,
        "head_sampling_rate": 0.05,
        "logs": {
          "enabled": true,
          "head_sampling_rate": 0.05,
          "invocation_logs": false,
        },
      },
      "triggers": {
        "crons": ["*/5 * * * *"],
      },
      "vars": {
        "ENVIRONMENT": "production",
        "REALTIME_INGEST_ENABLED": "true",
        "APP_BASE_URL": "https://lazuli.now",
        "PUBLIC_API_BASE_URL": "https://api.lazuli.now",
        "CORS_ORIGIN": "https://lazuli.now,https://www.lazuli.now",
        "ADMIN_API_KEY_ID": "lazuli-admin-production",
        "INGEST_SIGNING_SECRET_ID": "ingest-production-v1",
        "METRICS_INGEST_SECRET_ID": "metrics-production-v1",
        "REALTIME_TOKEN_SECRET_ID": "realtime-production-v1",
        "NOTIFICATION_ENCRYPTION_KEY_ID": "notifications-production-v1",
        "ALERT_WEBHOOK_SIGNING_SECRET_ID": "alert-webhook-production-v1",
        "MAGIC_LINK_EMAIL_FROM": "signin@lazuli.now",
        "ALERT_EMAIL_FROM": "alerts@lazuli.now",
        "OPERATIONAL_OWNER": "lazuli-operations",
        "INGEST_HEALTH_URL": "https://ingest.lazuli.now/control/health",
        "ALERT_USER_WEBHOOKS_ENABLED": "true",
        "ACCOUNT_FEATURES_ENABLED": "false",
        "ALERT_EVALUATION_ENABLED": "false",
        "ADMIN_ROUTES_ENABLED": "false",
      },
      "send_email": [
        {
          "name": "MAGIC_LINK_EMAIL",
          "allowed_sender_addresses": ["signin@lazuli.now"],
        },
        {
          "name": "ALERT_EMAIL",
          "allowed_sender_addresses": ["alerts@lazuli.now"],
        },
      ],
      "routes": [
        {
          "pattern": "api.lazuli.now/*",
          "zone_name": "lazuli.now",
        },
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "lazuli-db-prod",
          "database_id": "66e3ce0d-5467-4b0c-aee8-78bd52846e0f",
          "migrations_dir": "migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "OHLCV_ARCHIVE",
          "bucket_name": "lazuli-ohlcv-prod",
        },
      ],
      "queues": {
        "producers": [
          {
            "binding": "BACKFILL_QUEUE",
            "queue": "lazuli-backfill-prod",
          },
          {
            "binding": "ALERT_DELIVERY_QUEUE",
            "queue": "lazuli-alert-delivery-prod",
          },
        ],
        "consumers": [
          {
            "queue": "lazuli-backfill-prod",
            "max_batch_size": 10,
            "max_batch_timeout": 5,
            "max_retries": 5,
            "dead_letter_queue": "lazuli-backfill-dlq-prod",
          },
          {
            "queue": "lazuli-alert-delivery-prod",
            "max_batch_size": 10,
            "max_batch_timeout": 2,
            "max_retries": 5,
            "dead_letter_queue": "lazuli-alert-delivery-dlq-prod",
          },
        ],
      },
      "workflows": [
        {
          "name": "lazuli-backfill-prod",
          "binding": "BACKFILL_WORKFLOW",
          "class_name": "BackfillWorkflow",
          "limits": {
            "steps": 25000,
          },
        },
      ],
      "analytics_engine_datasets": [
        {
          "binding": "API_ANALYTICS",
          "dataset": "lazuli_api_prod",
        },
      ],
      "ratelimits": [
        {
          "name": "PUBLIC_RATE_LIMITER",
          "namespace_id": "698140721",
          "simple": { "limit": 240, "period": 60 },
        },
        {
          "name": "EXPENSIVE_RATE_LIMITER",
          "namespace_id": "698140722",
          "simple": { "limit": 30, "period": 60 },
        },
        {
          "name": "BUILDER_PUBLIC_RATE_LIMITER",
          "namespace_id": "698140723",
          "simple": { "limit": 1200, "period": 60 },
        },
        {
          "name": "BUILDER_EXPENSIVE_RATE_LIMITER",
          "namespace_id": "698140724",
          "simple": { "limit": 120, "period": 60 },
        },
        {
          "name": "EXCHANGE_RATE_LIMITER",
          "namespace_id": "698140725",
          "simple": { "limit": 50, "period": 10 },
        },
        {
          "name": "ADMIN_RATE_LIMITER",
          "namespace_id": "698140726",
          "simple": { "limit": 15, "period": 60 },
        },
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "MARKET_DATA_CACHE",
            "class_name": "MarketDataCacheV2DO",
          },
          {
            "name": "REALTIME_HUB",
            "class_name": "RealtimeHubV2DO",
          },
          {
            "name": "REALTIME_SEQUENCER",
            "class_name": "RealtimeSequencerV1DO",
          },
          {
            "name": "REALTIME_FANOUT",
            "class_name": "RealtimeFanoutV3DO",
          },
        ],
      },
    },
  },
}
