{
  "name": "@lazuli/api",
  "version": "0.1.0-alpha",
  "description": "Lazuli REST API - Cryptocurrency trading data service",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "build": "wrangler deploy --dry-run",
    "type-check": "wrangler types && tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply lazuli-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply lazuli-db --remote",
    "db:migrate:staging": "wrangler d1 migrations apply lazuli-db-staging --env staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply lazuli-db-prod --env production --remote",
    "test": "bun test src/**/*.test.ts",
    "test:routes": "node scripts/smoke-routes.mjs",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo .wrangler"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "api",
    "binance",
    "bybit",
    "okx",
    "cloudflare-workers"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@lazuli/eslint-config": "*",
    "@lazuli/typescript-config": "*",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@lazuli/shared": "*",
    "ccxt": "^4.5.59",
    "hono": "^4.12.26",
    "protobufjs": "^8.6.4",
    "zod": "^4.4.3"
  }
}
