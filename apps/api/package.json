{
  "name": "@lazuli/api",
  "version": "0.1.0-alpha",
  "description": "Lazuli REST API - Cryptocurrency trading data service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=./dist --target=bun --sourcemap",
    "start": "bun run dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "api",
    "binance",
    "bybit",
    "okx"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@lazuli/eslint-config": "*",
    "@lazuli/typescript-config": "*",
    "@types/node": "^24.0.4",
    "eslint": "^9.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "@lazuli/shared": "*",
    "@stoplight/elements": "^9.0.13",
    "@supabase/supabase-js": "^2.50.2",
    "axios": "^1.12.0",
    "ccxt": "^4.4.91",
    "dotenv": "^16.5.0",
    "elysia": "^1.4.18",
    "ioredis": "^5.8.2",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  }
}
