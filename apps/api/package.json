{
  "name": "@lazuli/api",
  "version": "0.1.0-alpha",
  "description": "Lazuli REST API - Cryptocurrency trading data service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=./dist --target=bun --sourcemap",
    "start": "bun run dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "api",
    "binance",
    "bybit",
    "okx"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@lazuli/eslint-config": "*",
    "@lazuli/typescript-config": "*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.4",
    "eslint": "^9.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@lazuli/shared": "*",
    "@stoplight/elements": "^9.0.2",
    "@supabase/supabase-js": "^2.50.2",
    "axios": "^1.10.0",
    "ccxt": "^4.4.91",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ioredis": "^5.8.2"
  }
}
