# Lazuli API local development defaults
#
# The API runs on Cloudflare Workers. D1, R2, Queue, Workflow, Analytics, and
# Durable Object bindings are declared in wrangler.jsonc.

ENVIRONMENT=local
PUBLIC_API_BASE_URL=http://localhost:8787
CORS_ORIGIN=http://localhost:3001
ADMIN_API_KEY=replace-with-local-admin-key
ACCOUNT_FEATURES_ENABLED=true
ALERT_EVALUATION_ENABLED=true
ADMIN_ROUTES_ENABLED=true

# Staging/production use ADMIN_API_KEY_ID from wrangler.jsonc and
# ADMIN_SIGNING_SECRET from Wrangler secrets.

# Optional alert delivery relay. The relay owns provider credentials for
# Telegram, Discord, email, and webhook destinations.
ALERT_DELIVERY_WEBHOOK_URL=
ALERT_DELIVERY_WEBHOOK_SECRET=

# Optional first-party alert delivery adapters. Store provider secrets in
# Worker secrets/vars, never in D1 alert delivery JSON.
ALERT_EMAIL_DELIVERY_WEBHOOK_URL=
ALERT_EMAIL_DELIVERY_WEBHOOK_SECRET=
ALERT_DISCORD_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_USER_WEBHOOKS_ENABLED=false
ALERT_WEBHOOK_SIGNING_SECRET=
